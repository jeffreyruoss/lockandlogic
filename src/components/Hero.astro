---
import { Image } from 'astro:assets';
import logo from '../assets/logo.webp';
import heroBg from '../assets/hero-bg.webp';
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden">
  <!-- Background image -->
  <Image
    src={heroBg}
    alt=""
    widths={[768, 1280, 1920]}
    sizes="100vw"
    class="absolute inset-0 h-full w-full object-cover"
    loading="eager"
  />
  <!-- Dark overlay for text readability -->
  <div class="absolute inset-0 bg-navy-950/60"></div>

  <!-- Subtle grid pattern overlay -->
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: linear-gradient(rgba(200,205,216,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(200,205,216,0.3) 1px, transparent 1px); background-size: 60px 60px;"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 mx-auto max-w-5xl px-4 py-20 text-center sm:px-6 lg:px-8">
    <!-- Logo with glow -->
    <div class="relative mx-auto mb-10 w-72 sm:w-80 lg:w-96">
      <div class="absolute inset-0 scale-110 rounded-full bg-gold-400/[0.06] blur-3xl" aria-hidden="true"></div>
      <Image
        src={logo}
        alt="Lock & Logic"
        width={400}
        class="relative mx-auto drop-shadow-[0_0_30px_rgba(212,168,67,0.15)]"
      />
    </div>

    <p class="mb-5 text-sm font-semibold uppercase tracking-[0.25em] text-teal-400 text-glow-teal">
      Pottstown, PA &mdash; Opening May 2026
    </p>

    <h1 class="text-gold-gradient text-glow-gold mb-6 font-heading text-5xl font-bold leading-tight sm:text-6xl lg:text-8xl">
      Unlock the Mystery
    </h1>

    <p class="mx-auto mb-12 max-w-2xl text-lg leading-relaxed text-steel-200 sm:text-xl">
      Immersive escape room experiences where every clue counts and every second matters.
    </p>

    <div class="flex flex-col items-center gap-5 sm:flex-row sm:justify-center">
      <a
        href="/book"
        class="group relative overflow-hidden rounded-xl bg-gold-400 px-10 py-4 text-base font-bold text-navy-950 transition-all duration-300 hover:bg-gold-500 hover:scale-105"
        style="animation: glow-pulse 3s ease-in-out infinite;"
      >
        <span class="relative z-10">Book Your Escape</span>
      </a>

      <a
        href="/rooms"
        class="group inline-flex items-center gap-2 rounded-xl border border-steel-400/20 px-8 py-4 text-base font-medium text-steel-200 backdrop-blur-sm transition-all duration-300 hover:border-gold-400/40 hover:text-gold-300"
      >
        Explore Our Rooms
        <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="mt-16 flex justify-center" aria-hidden="true">
      <div class="flex h-10 w-6 items-start justify-center rounded-full border border-steel-400/30 p-1.5">
        <div class="h-2 w-1 animate-bounce rounded-full bg-gold-400/60"></div>
      </div>
    </div>
  </div>
</section>
