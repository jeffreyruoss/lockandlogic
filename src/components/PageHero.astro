---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="relative overflow-hidden py-20 sm:py-24">
  <div
    class="absolute inset-0"
    style="background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(26,34,64,0.9) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 80% 80%, rgba(212,168,67,0.04) 0%, transparent 60%),
      var(--color-navy-950);"
    aria-hidden="true"
  ></div>
  <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-gold-400/20 to-transparent" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
    <h1 class="text-gold-gradient font-heading text-4xl font-bold sm:text-5xl">{title}</h1>
    {subtitle && <p class="mt-4 text-lg text-steel-400">{subtitle}</p>}
  </div>
</section>
