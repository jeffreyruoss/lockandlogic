---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<details class="group rounded-xl border border-navy-700/50 bg-navy-900 transition-colors hover:border-gold-400/20">
  <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-sm font-semibold text-steel-100 [&::-webkit-details-marker]:hidden">
    <span>{question}</span>
    <svg class="h-5 w-5 shrink-0 text-steel-400 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
  </summary>
  <div class="border-t border-navy-700/50 px-6 py-4">
    <p class="text-sm leading-relaxed text-steel-400">{answer}</p>
  </div>
</details>
