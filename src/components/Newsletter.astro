<section class="relative overflow-hidden py-24">
  <div class="absolute inset-0 bg-navy-900" aria-hidden="true"></div>
  <div class="absolute left-1/2 top-0 h-px w-3/4 -translate-x-1/2 bg-gradient-to-r from-transparent via-teal-400/20 to-transparent" aria-hidden="true"></div>
  <div class="absolute -left-32 top-1/2 h-80 w-80 -translate-y-1/2 rounded-full bg-teal-400/[0.04] blur-3xl" aria-hidden="true"></div>
  <div class="absolute -right-32 top-1/2 h-80 w-80 -translate-y-1/2 rounded-full bg-gold-400/[0.04] blur-3xl" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <div class="reveal">
      <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.3em] text-teal-400 text-glow-teal">Don't Miss Out</span>
      <h2 class="text-gold-gradient text-glow-gold mb-4 font-heading text-4xl font-bold sm:text-5xl">Stay in the Loop</h2>
      <p class="mb-10 text-lg text-steel-400">
        Be the first to hear about new rooms, special offers, and our grand opening.
      </p>

      <form action="#" method="POST" class="mx-auto flex max-w-lg flex-col gap-3 sm:flex-row">
        <label for="newsletter-email" class="sr-only">Email address</label>
        <input
          type="email"
          id="newsletter-email"
          name="email"
          required
          placeholder="you@example.com"
          class="flex-1 rounded-xl border border-white/[0.08] bg-navy-950/80 px-5 py-3.5 text-sm text-steel-100 placeholder-steel-400 outline-none backdrop-blur-sm transition-all duration-300 focus:border-gold-400/60 focus:shadow-[0_0_15px_rgba(212,168,67,0.1)]"
        />
        <button
          type="submit"
          class="rounded-xl bg-gold-400 px-8 py-3.5 text-sm font-bold text-navy-950 transition-all duration-300 hover:bg-gold-500 hover:shadow-[0_0_20px_rgba(212,168,67,0.25)]"
        >
          Subscribe
        </button>
      </form>

      <p class="mt-4 text-xs text-steel-400">No spam. Unsubscribe anytime.</p>
    </div>
  </div>
</section>
