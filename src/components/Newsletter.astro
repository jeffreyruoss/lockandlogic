<section class="relative overflow-hidden bg-gradient-to-r from-navy-800 to-navy-900 py-20">
  <!-- Teal accent glow -->
  <div class="absolute -right-20 top-1/2 h-64 w-64 -translate-y-1/2 rounded-full bg-teal-400/5 blur-3xl" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-gold-gradient mb-4 font-heading text-3xl font-bold sm:text-4xl">Stay in the Loop</h2>
    <p class="mb-8 text-steel-400">
      Be the first to hear about new rooms, special offers, and our grand opening details.
    </p>

    <form action="#" method="POST" class="mx-auto flex max-w-md flex-col gap-3 sm:flex-row">
      <label for="newsletter-email" class="sr-only">Email address</label>
      <input
        type="email"
        id="newsletter-email"
        name="email"
        required
        placeholder="you@example.com"
        class="flex-1 rounded-lg border border-navy-700 bg-navy-950 px-4 py-3 text-sm text-steel-100 placeholder-steel-400 outline-none transition-colors focus:border-gold-400"
      />
      <button
        type="submit"
        class="rounded-lg bg-gold-400 px-6 py-3 text-sm font-bold text-navy-950 transition-colors hover:bg-gold-500"
      >
        Subscribe
      </button>
    </form>

    <p class="mt-4 text-xs text-steel-400">No spam. Unsubscribe anytime.</p>
  </div>
</section>
