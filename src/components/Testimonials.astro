---
const testimonials = [
  {
    quote: "The Vault was hands down the best escape room we've ever done. The puzzles were creative, the set design was incredible, and the staff made us feel like real bank robbers. We'll definitely be back for Circuit Breaker!",
    name: 'Sarah M.',
    context: 'The Vault — Team of 4',
  },
  {
    quote: "We brought our team of six for a corporate outing and had an absolute blast. The Forgotten Library had us stumped a few times, but the 'aha!' moments made it so worth it. Highly recommend for team building!",
    name: 'Jason R.',
    context: 'The Forgotten Library — Corporate Event',
  },
  {
    quote: "My kids (ages 14 and 16) loved it just as much as we did. Lock & Logic is the perfect mix of challenging and fun. The atmosphere is top-notch — dark, immersive, and genuinely exciting.",
    name: 'Amanda T.',
    context: 'Circuit Breaker — Family Night',
  },
];
---

<section class="relative py-24">
  <div class="absolute left-1/2 top-0 h-px w-3/4 -translate-x-1/2 bg-gradient-to-r from-transparent via-gold-400/15 to-transparent" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mb-14 text-center">
      <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.3em] text-teal-400 text-glow-teal">Real Escapes, Real Reviews</span>
      <h2 class="text-gold-gradient text-glow-gold font-heading text-4xl font-bold sm:text-5xl">What Players Say</h2>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {testimonials.map(({ quote, name, context }, i) => (
        <blockquote class="reveal group relative overflow-hidden rounded-2xl border border-white/[0.06] bg-navy-900/40 p-7 backdrop-blur-sm transition-all duration-500 hover:border-white/[0.12] hover:card-elevated" style={`animation-delay: ${i * 0.1}s;`}>
          <span class="absolute -left-2 -top-6 font-heading text-8xl leading-none text-gold-400/[0.07] transition-colors duration-500 group-hover:text-gold-400/[0.12]" aria-hidden="true">&ldquo;</span>

          <div class="relative mb-4 flex gap-0.5" aria-label="5 out of 5 stars">
            {Array.from({ length: 5 }).map(() => (
              <svg class="h-4 w-4 text-gold-400 drop-shadow-[0_0_3px_rgba(212,168,67,0.3)]" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <p class="relative mb-5 text-sm leading-relaxed text-steel-200">{quote}</p>

          <footer>
            <div class="text-sm font-semibold text-gold-400">{name}</div>
            <div class="text-xs text-steel-400">{context}</div>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
