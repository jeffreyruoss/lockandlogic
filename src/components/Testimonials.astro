---
const testimonials = [
  {
    quote: "The Vault was hands down the best escape room we've ever done. The puzzles were creative, the set design was incredible, and the staff made us feel like real bank robbers. We'll definitely be back for Circuit Breaker!",
    name: 'Sarah M.',
  },
  {
    quote: "We brought our team of six for a corporate outing and had an absolute blast. The Forgotten Library had us stumped a few times, but the 'aha!' moments made it so worth it. Highly recommend for team building!",
    name: 'Jason R.',
  },
  {
    quote: "My kids (ages 14 and 16) loved it just as much as we did. Lock & Logic is the perfect mix of challenging and fun. The atmosphere is top-notch — dark, immersive, and genuinely exciting.",
    name: 'Amanda T.',
  },
];
---

<section class="py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <h2 class="text-gold-gradient font-heading text-3xl font-bold sm:text-4xl">What Players Say</h2>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {testimonials.map(({ quote, name }) => (
        <blockquote class="relative rounded-xl border border-navy-700/50 bg-navy-900 p-6">
          <span class="absolute -top-4 left-4 font-heading text-6xl leading-none text-gold-400/15" aria-hidden="true">&ldquo;</span>

          <!-- 5-star rating -->
          <div class="mb-3 flex gap-0.5" aria-label="5 out of 5 stars">
            {Array.from({ length: 5 }).map(() => (
              <svg class="h-4 w-4 text-gold-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <p class="mb-4 text-sm leading-relaxed text-steel-200">{quote}</p>
          <footer class="text-sm font-semibold text-gold-400">&mdash; {name}</footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
