---
import { Image } from 'astro:assets';
import icon from '../assets/icon.webp';
import { baseUrl } from '../utils/url';

const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Rooms', href: baseUrl('/rooms') },
  { label: 'Leaderboard', href: baseUrl('/leaderboard') },
  { label: 'Groups', href: baseUrl('/groups') },
  { label: 'Gift Cards', href: baseUrl('/gift-cards') },
  { label: 'FAQ', href: baseUrl('/faq') },
  { label: 'Contact', href: baseUrl('/contact') },
];
---

<header class="sticky top-0 z-50 border-b border-navy-700/50 bg-navy-950/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <a href={baseUrl('/')} class="flex shrink-0 items-center gap-2">
      <Image
        src={icon}
        alt=""
        height={80}
        quality={100}
        class="h-10 w-auto"
      />
      <span class="font-heading text-lg uppercase tracking-wider text-white">Lock <span class="text-gold-400">&</span> Logic</span>
    </a>

    <nav aria-label="Main navigation" class="hidden items-center gap-1 md:flex">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            'rounded-md px-3 py-2 text-sm font-medium transition-colors',
            currentPath === href || currentPath.startsWith(href + '/')
              ? 'text-gold-400'
              : 'text-steel-200 hover:text-gold-300',
          ]}
          aria-current={currentPath === href || currentPath.startsWith(href + '/') ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
      <a
        href={baseUrl('/book')}
        class="ml-3 rounded-md bg-gold-400 px-5 py-2 text-sm font-bold text-navy-950 transition-colors hover:bg-gold-500"
      >
        Book Now
      </a>
    </nav>

    <button
      id="mobile-menu-btn"
      type="button"
      class="inline-flex items-center justify-center rounded-md p-2 text-steel-200 hover:text-gold-300 md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle navigation menu"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path id="icon-open" stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        <path id="icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-navy-700/50 md:hidden"
    aria-label="Mobile navigation"
  >
    <div class="space-y-1 px-4 pb-4 pt-2">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            'block rounded-md px-3 py-2 text-base font-medium transition-colors',
            currentPath === href || currentPath.startsWith(href + '/')
              ? 'text-gold-400'
              : 'text-steel-200 hover:text-gold-300',
          ]}
          aria-current={currentPath === href || currentPath.startsWith(href + '/') ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
      <a
        href={baseUrl('/book')}
        class="mt-2 block rounded-md bg-gold-400 px-3 py-2 text-center text-base font-bold text-navy-950 transition-colors hover:bg-gold-500"
      >
        Book Now
      </a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  function toggleMenu(forceClose = false) {
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    const shouldClose = forceClose || isOpen;
    btn.setAttribute('aria-expanded', String(!shouldClose));
    menu.classList.toggle('hidden', shouldClose);
    iconOpen.classList.toggle('hidden', !shouldClose);
    iconClose.classList.toggle('hidden', shouldClose);

    if (!shouldClose) {
      const firstLink = menu.querySelector('a');
      firstLink?.focus();
    } else {
      btn.focus();
    }
  }

  btn.addEventListener('click', () => toggleMenu());

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') {
      toggleMenu(true);
    }
  });
</script>
