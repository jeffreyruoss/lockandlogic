---
const inputClasses =
  'w-full rounded-lg border border-navy-700 bg-navy-950 px-4 py-3 text-sm text-steel-100 placeholder-steel-400 outline-none transition-colors focus:border-gold-400';
const selectClasses =
  'w-full rounded-lg border border-navy-700 bg-navy-950 px-4 py-3 text-sm text-steel-100 outline-none transition-colors focus:border-gold-400';
---

<form action="https://formspree.io/f/placeholder" method="POST" class="space-y-5">
  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="inquiry-name" class="mb-1.5 block text-sm font-medium text-steel-100">Name</label>
      <input type="text" id="inquiry-name" name="name" required autocomplete="name" placeholder="Your name" class={inputClasses} />
    </div>
    <div>
      <label for="inquiry-company" class="mb-1.5 block text-sm font-medium text-steel-100">Company</label>
      <input type="text" id="inquiry-company" name="company" required autocomplete="organization" placeholder="Company name" class={inputClasses} />
    </div>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="inquiry-email" class="mb-1.5 block text-sm font-medium text-steel-100">Email</label>
      <input type="email" id="inquiry-email" name="email" required autocomplete="email" placeholder="you@company.com" class={inputClasses} />
    </div>
    <div>
      <label for="inquiry-phone" class="mb-1.5 block text-sm font-medium text-steel-100">Phone</label>
      <input type="tel" id="inquiry-phone" name="phone" autocomplete="tel" placeholder="(555) 123-4567" class={inputClasses} />
    </div>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="inquiry-size" class="mb-1.5 block text-sm font-medium text-steel-100">Group Size</label>
      <input type="number" id="inquiry-size" name="group_size" min="2" max="500" placeholder="Number of participants" class={inputClasses} />
    </div>
    <div>
      <label for="inquiry-type" class="mb-1.5 block text-sm font-medium text-steel-100">Event Type</label>
      <select id="inquiry-type" name="event_type" class={selectClasses}>
        <option value="" disabled selected>Select event type</option>
        <option value="team-building">Team Building</option>
        <option value="corporate-outing">Corporate Outing</option>
        <option value="birthday">Birthday Party</option>
        <option value="celebration">Celebration / Special Event</option>
        <option value="other">Other</option>
      </select>
    </div>
  </div>

  <div>
    <label for="inquiry-date" class="mb-1.5 block text-sm font-medium text-steel-100">Preferred Date <span class="text-steel-400">(optional)</span></label>
    <input type="date" id="inquiry-date" name="preferred_date" class={inputClasses} />
  </div>

  <div>
    <label for="inquiry-message" class="mb-1.5 block text-sm font-medium text-steel-100">Additional Details</label>
    <textarea id="inquiry-message" name="message" rows="4" placeholder="Tell us about your event..." class={inputClasses}></textarea>
  </div>

  <button
    type="submit"
    class="w-full rounded-lg bg-gold-400 px-6 py-3 text-sm font-bold text-navy-950 transition-colors hover:bg-gold-500"
  >
    Submit Inquiry
  </button>
</form>
