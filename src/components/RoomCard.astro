---
interface Props {
  name: string;
  description: string;
  difficulty: 'Beginner' | 'Intermediate' | 'Advanced';
  players: string;
  duration: string;
  price: string;
  slug: string;
  gradientFrom?: string;
  gradientTo?: string;
}

const {
  name,
  description,
  difficulty,
  players,
  duration,
  price,
  slug,
  gradientFrom = 'from-navy-700',
  gradientTo = 'to-navy-900',
} = Astro.props;

const difficultyColors: Record<string, string> = {
  Beginner: 'bg-teal-400/20 text-teal-400',
  Intermediate: 'bg-gold-400/20 text-gold-400',
  Advanced: 'bg-red-500/20 text-red-400',
};
---

<article class="group flex flex-col overflow-hidden rounded-xl border border-navy-700/50 bg-navy-900 transition-colors hover:border-gold-400/30">
  <!-- Gradient placeholder image area -->
  <div class={`h-48 bg-gradient-to-br ${gradientFrom} ${gradientTo} relative`}>
    <div class="absolute inset-0 bg-gradient-to-t from-navy-900 to-transparent opacity-60"></div>
    <span class={`absolute left-3 top-3 rounded-full px-3 py-1 text-xs font-bold ${difficultyColors[difficulty]}`}>
      {difficulty}
    </span>
  </div>

  <div class="flex flex-1 flex-col p-5">
    <h3 class="mb-2 font-heading text-xl font-bold text-steel-100">{name}</h3>
    <p class="mb-4 line-clamp-2 text-sm text-steel-400">{description}</p>

    <!-- Info row -->
    <div class="mt-auto mb-4 flex items-center gap-4 text-xs text-steel-400">
      <span class="inline-flex items-center gap-1">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128H9m6 0a5.972 5.972 0 0 0-.786-3.07M9 19.128v-.003c0-1.113.285-2.16.786-3.07m0 0a5.972 5.972 0 0 1 6.428 0M9.786 16.058A5.967 5.967 0 0 1 12 15c1.05 0 2.034.27 2.893.739M12 12a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" /></svg>
        {players}
      </span>
      <span class="inline-flex items-center gap-1">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
        {duration}
      </span>
      <span class="inline-flex items-center gap-1">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" /></svg>
        {price}
      </span>
    </div>

    <a
      href={`/book?room=${slug}`}
      class="inline-flex items-center justify-center rounded-md bg-gold-400/10 px-4 py-2 text-sm font-semibold text-gold-400 transition-colors hover:bg-gold-400 hover:text-navy-950"
    >
      Book This Room
    </a>
  </div>
</article>
