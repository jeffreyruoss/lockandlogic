---
import RoomCard from './RoomCard.astro';
import { rooms } from '../data/rooms';
import { baseUrl } from '../utils/url';
---

<section class="relative bg-navy-950 py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mb-4 text-center">
      <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.3em] text-teal-400 text-glow-teal">Choose Your Challenge</span>
      <h2 class="text-gold-gradient text-glow-gold font-heading text-4xl font-bold sm:text-5xl">Our Escape Rooms</h2>
      <p class="mt-4 text-lg text-steel-400">Four worlds. One hour. No second chances.</p>
    </div>

    <div class="mt-14 grid gap-8 md:grid-cols-2">
      {rooms.map((room, i) => (
        <div class="reveal" style={`animation-delay: ${(i + 1) * 0.1}s;`}>
          <RoomCard
            name={room.name}
            description={room.description}
            difficulty={room.difficulty}
            players={room.players}
            duration={room.duration}
            price={room.price}
            slug={room.slug}
            image={room.image}
            gradientFrom={room.gradientFrom}
            gradientTo={room.gradientTo}
          />
        </div>
      ))}
    </div>

    <div class="reveal mt-12 text-center">
      <a
        href={baseUrl('/rooms')}
        class="group inline-flex items-center gap-2 rounded-full border border-steel-400/20 px-6 py-3 text-sm font-medium text-steel-200 transition-all duration-300 hover:border-gold-400/40 hover:text-gold-300"
      >
        View All Rooms
        <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
