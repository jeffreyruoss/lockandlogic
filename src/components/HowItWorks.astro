---
const steps = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />`,
    title: 'Book',
    description: 'Pick your room and reserve your time slot online.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />`,
    title: 'Arrive',
    description: 'Check in 15 minutes early for your briefing.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 0 1-.657.643 48.486 48.486 0 0 1-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 0 1-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 0 0-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 0 1-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 0 0 .657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 0 1-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 0 0 5.427-.63 48.05 48.05 0 0 0 .582-4.717.532.532 0 0 0-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.96.401v0a.656.656 0 0 0 .658-.663 48.422 48.422 0 0 0-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 0 1-.61-.58v0Z" />`,
    title: 'Play',
    description: 'Work together to solve puzzles and crack codes.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5V6.75a4.5 4.5 0 1 1 9 0v3.75M3.75 21.75h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H3.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />`,
    title: 'Escape',
    description: 'Beat the clock and earn your place on the leaderboard.',
  },
];
---

<section class="bg-navy-900 py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <h2 class="text-gold-gradient font-heading text-3xl font-bold sm:text-4xl">How It Works</h2>
      <p class="mt-4 text-steel-400">Your escape begins in four simple steps.</p>
    </div>

    <div class="relative grid gap-8 md:grid-cols-4">
      <!-- Connecting line (desktop) -->
      <div class="absolute left-0 right-0 top-10 z-0 hidden border-t border-dashed border-navy-700 md:block" aria-hidden="true"></div>

      {steps.map((step, i) => (
        <div class="relative z-10 flex flex-col items-center text-center">
          <div class="mb-4 flex h-20 w-20 items-center justify-center rounded-full border border-navy-700 bg-navy-950">
            <svg class="h-8 w-8 text-teal-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" set:html={step.icon} />
          </div>
          <span class="mb-1 text-xs font-bold uppercase tracking-wider text-steel-400">Step {i + 1}</span>
          <h3 class="mb-2 font-heading text-lg font-bold text-gold-400">{step.title}</h3>
          <p class="text-sm text-steel-400">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
