---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import InquiryForm from '../components/InquiryForm.astro';
import { Image } from 'astro:assets';
import teamCollaboration from '../assets/team-collaboration.webp';
---

<BaseLayout title="Corporate & Group Events" description="Team building that actually works. Book private escape room experiences for corporate events, parties, and large groups.">
  <PageHero title="Corporate & Group Events" subtitle="Team building that actually works." />

  <!-- Why Escape Rooms -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <h2 class="text-gold-gradient mb-6 font-heading text-3xl font-bold">Why Escape Rooms for Team Building?</h2>
          <div class="space-y-4 text-steel-200">
            <p>
              Forget trust falls and awkward icebreakers. Escape rooms put your team in a high-energy, collaborative environment where real communication and problem-solving skills emerge naturally.
            </p>
            <p>
              In 60 minutes, you'll see who leads, who listens, who thinks outside the box, and who keeps the group focused under pressure. It's the most fun your team will ever have while learning to work together better.
            </p>
          </div>
          <Image
            src={teamCollaboration}
            alt="Corporate team collaborating together"
            width={600}
            class="mt-6 rounded-xl"
          />
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            {
              icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 0 1-.825-.242m9.345-8.334a2.126 2.126 0 0 0-.476-.095 48.64 48.64 0 0 0-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0 0 11.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />',
              title: 'Communication',
              description: 'Teams must share information and listen actively to solve puzzles.',
            },
            {
              icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />',
              title: 'Problem Solving',
              description: 'Multi-layered puzzles require creative and analytical thinking.',
            },
            {
              icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />',
              title: 'Leadership',
              description: 'Natural leaders emerge when the clock is ticking.',
            },
            {
              icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 0 1-6.364 0M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0ZM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Z" />',
              title: 'Morale',
              description: 'Shared victories (and funny failures) build lasting team bonds.',
            },
          ].map((item) => (
            <div class="rounded-xl border border-navy-700/50 bg-navy-900 p-5 text-center">
              <svg class="mx-auto mb-3 h-8 w-8 text-teal-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" set:html={item.icon} />
              <h3 class="mb-1 font-heading text-base font-bold text-steel-100">{item.title}</h3>
              <p class="text-xs text-steel-400">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- What We Offer -->
  <section class="border-t border-navy-700/50 bg-navy-900 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center font-heading text-2xl font-bold text-steel-100">What We Offer</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {[
          {
            title: 'Private Bookings',
            description: 'Reserve an entire room for just your group. No strangers, no distractions — just your team and the clock.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />',
          },
          {
            title: 'Custom Packages',
            description: 'Combine escape rooms with catering, facilitated debriefs, and team awards for a complete corporate experience.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 1 0 9.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1 1 14.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />',
          },
          {
            title: 'Large Groups',
            description: 'Groups of 20+ can play multiple rooms simultaneously and compete head-to-head for bragging rights.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />',
          },
        ].map((item) => (
          <div class="rounded-xl border border-navy-700/50 bg-navy-950 p-6 text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full border border-navy-700 bg-navy-900">
              <svg class="h-6 w-6 text-gold-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" set:html={item.icon} />
            </div>
            <h3 class="mb-2 font-heading text-lg font-bold text-steel-100">{item.title}</h3>
            <p class="text-sm text-steel-400">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Inquiry Form -->
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="mb-8 text-center">
        <h2 class="text-gold-gradient font-heading text-3xl font-bold">Get a Custom Quote</h2>
        <p class="mt-4 text-steel-400">Tell us about your event and we'll put together a package that fits.</p>
      </div>
      <InquiryForm />
    </div>
  </section>

  <!-- Testimonial -->
  <section class="border-t border-navy-700/50 bg-navy-900 py-16">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <span class="font-heading text-6xl leading-none text-gold-400/15" aria-hidden="true">&ldquo;</span>
      <blockquote class="mt-2">
        <p class="text-lg leading-relaxed text-steel-200">
          We brought our team of six for a corporate outing and had an absolute blast. The Initiation had us stumped a few times, but the 'aha!' moments made it so worth it. Lock & Logic handled everything — setup, facilitation, even the post-game debrief. Highly recommend for team building!
        </p>
        <footer class="mt-6">
          <p class="font-semibold text-gold-400">Jason R.</p>
          <p class="text-sm text-steel-400">Marketing Director, Vertex Solutions</p>
        </footer>
      </blockquote>
    </div>
  </section>
</BaseLayout>
