---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ResovaEmbed from '../components/ResovaEmbed.astro';
---

<BaseLayout title="Gift Cards" description="Give the gift of adventure. Lock & Logic gift cards are perfect for birthdays, holidays, and any occasion.">
  <PageHero title="Gift Cards" subtitle="Give the gift of adventure." />

  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 mx-auto max-w-2xl text-center">
        <p class="text-steel-200">
          Looking for the perfect gift? Lock & Logic gift cards let your friends and family choose their own escape room adventure. Great for birthdays, holidays, date nights, or just because.
        </p>
      </div>

      <ResovaEmbed type="gift-voucher" />

      <!-- How It Works -->
      <div class="mt-16">
        <h2 class="mb-8 text-center font-heading text-2xl font-bold text-steel-100">How It Works</h2>
        <div class="grid gap-6 sm:grid-cols-3">
          {[
            {
              step: '1',
              title: 'Purchase',
              description: 'Choose a gift card amount and complete your purchase online. It takes less than a minute.',
              icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z" />',
            },
            {
              step: '2',
              title: 'Deliver',
              description: 'The recipient gets a beautifully designed digital gift card delivered straight to their inbox.',
              icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />',
            },
            {
              step: '3',
              title: 'Play',
              description: 'They book their preferred room and time online, apply the gift card at checkout, and enjoy the adventure.',
              icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 0 1-.657.643 48.486 48.486 0 0 1-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 0 1-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 0 0-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 0 1-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 0 0 .657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 0 1-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 0 0 5.427-.63 48.05 48.05 0 0 0 .582-4.717.532.532 0 0 0-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.96.401v0a.656.656 0 0 0 .658-.663 48.422 48.422 0 0 0-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 0 1-.61-.58v0Z" />',
            },
          ].map((item) => (
            <div class="rounded-xl border border-navy-700/50 bg-navy-900 p-6 text-center">
              <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full border border-navy-700 bg-navy-950">
                <svg class="h-6 w-6 text-teal-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" set:html={item.icon} />
              </div>
              <span class="mb-1 block text-xs font-bold uppercase tracking-wider text-steel-400">Step {item.step}</span>
              <h3 class="mb-2 font-heading text-lg font-bold text-gold-400">{item.title}</h3>
              <p class="text-sm text-steel-400">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
