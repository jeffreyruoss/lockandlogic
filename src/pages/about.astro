---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { Image } from 'astro:assets';
import logo from '../assets/logo.webp';
---

<BaseLayout title="About" description="Learn about Lock & Logic — Pottstown's newest escape room destination. Our story, our team, and what to expect.">
  <PageHero title="About Lock & Logic" subtitle="Where every puzzle tells a story and every escape creates a memory." />

  <!-- Our Story -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <h2 class="text-gold-gradient mb-6 font-heading text-3xl font-bold">Our Story</h2>
          <div class="space-y-4 text-steel-200">
            <p>
              Lock & Logic was born from a simple belief: the best adventures happen when you step away from your screen and into a story. We're building something different in Pottstown — escape rooms that feel like living, breathing worlds.
            </p>
            <p>
              Every room is designed from the ground up with hand-crafted puzzles, atmospheric set design, and narratives that pull you in from the moment the door locks behind you. No padlock hunts, no flimsy props — just clever, immersive experiences that challenge your mind and spark your imagination.
            </p>
            <p>
              We believe escape rooms are more than entertainment. They're a way to connect — with friends, with family, with coworkers. In a world full of distractions, we create spaces where the only thing that matters is the puzzle in front of you and the people beside you.
            </p>
          </div>
        </div>
        <div class="flex items-center justify-center">
          <div class="relative">
            <div class="absolute -inset-4 rounded-2xl bg-gradient-to-br from-gold-400/10 to-teal-400/10 blur-xl"></div>
            <Image
              src={logo}
              alt="Lock & Logic logo"
              width={320}
              class="relative w-64 lg:w-80"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Meet the Team -->
  <section class="border-t border-navy-700/50 bg-navy-900 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <h2 class="text-gold-gradient font-heading text-3xl font-bold">Meet the Team</h2>
        <p class="mt-4 text-steel-400">The people behind the puzzles.</p>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {[
          {
            name: 'Alex Morgan',
            title: 'Founder & Lead Designer',
            bio: 'A lifelong puzzle enthusiast who left a career in software engineering to build immersive experiences. Alex designs every room from concept to final clue.',
            gradient: 'from-gold-400/20 to-amber-900/20',
          },
          {
            name: 'Jordan Chen',
            title: 'Operations Manager',
            bio: 'With a background in hospitality and event management, Jordan ensures every visit runs smoothly — from booking to the final "aha!" moment.',
            gradient: 'from-teal-500/20 to-navy-800',
          },
          {
            name: 'Sam Rivera',
            title: 'Game Master & Community Lead',
            bio: 'Equal parts storyteller and host, Sam brings each room to life with engaging briefings and perfectly-timed hints. Also runs our social media and events.',
            gradient: 'from-purple-900/20 to-navy-800',
          },
        ].map((member) => (
          <div class="rounded-xl border border-navy-700/50 bg-navy-950 p-6 text-center">
            <div class={`mx-auto mb-4 h-24 w-24 rounded-full bg-gradient-to-br ${member.gradient}`}></div>
            <h3 class="mb-1 font-heading text-xl font-bold text-steel-100">{member.name}</h3>
            <p class="mb-3 text-sm font-medium text-gold-400">{member.title}</p>
            <p class="text-sm text-steel-400">{member.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <h2 class="text-gold-gradient font-heading text-3xl font-bold">What to Expect</h2>
        <p class="mt-4 text-steel-400">Your visit in four simple steps.</p>
      </div>

      <div class="relative grid gap-8 md:grid-cols-4">
        <div class="absolute left-0 right-0 top-10 z-0 hidden border-t border-dashed border-navy-700 md:block" aria-hidden="true"></div>
        {[
          {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />',
            step: 'Step 1',
            title: 'Arrive',
            description: 'Show up 15 minutes early. We\'ll greet you, store your belongings, and get you checked in.',
          },
          {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75" />',
            step: 'Step 2',
            title: 'Briefing',
            description: 'Your Game Master sets the scene, explains the rules, and gets you into character.',
          },
          {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 0 1-.657.643 48.486 48.486 0 0 1-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 0 1-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 0 0-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 0 1-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 0 0 .657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 0 1-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 0 0 5.427-.63 48.05 48.05 0 0 0 .582-4.717.532.532 0 0 0-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.96.401v0a.656.656 0 0 0 .658-.663 48.422 48.422 0 0 0-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 0 1-.61-.58v0Z" />',
            step: 'Step 3',
            title: 'Play',
            description: 'Work together to solve puzzles, crack codes, and uncover secrets. 60 minutes on the clock.',
          },
          {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .982-3.172M8.25 8.75a1.5 1.5 0 0 1 1.5-1.5h4.5a1.5 1.5 0 0 1 1.5 1.5v.375c0 .621-.504 1.125-1.125 1.125H9.375A1.125 1.125 0 0 1 8.25 9.125V8.75Z" />',
            step: 'Step 4',
            title: 'Celebrate',
            description: 'Win or lose, celebrate with your team. Take a group photo and check the leaderboard.',
          },
        ].map((item) => (
          <div class="relative z-10 flex flex-col items-center text-center">
            <div class="mb-4 flex h-20 w-20 items-center justify-center rounded-full border border-navy-700 bg-navy-950">
              <svg class="h-8 w-8 text-teal-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" set:html={item.icon} />
            </div>
            <span class="mb-1 text-xs font-bold uppercase tracking-wider text-steel-400">{item.step}</span>
            <h3 class="mb-2 font-heading text-lg font-bold text-gold-400">{item.title}</h3>
            <p class="text-sm text-steel-400">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-navy-700/50 bg-gradient-to-r from-navy-800 to-navy-900 py-16">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-gold-gradient mb-4 font-heading text-3xl font-bold">Ready for Your First Escape?</h2>
      <p class="mb-8 text-steel-400">Pick a room, gather your team, and see if you have what it takes.</p>
      <a
        href="/book"
        class="inline-flex items-center rounded-lg bg-gold-400 px-8 py-3.5 text-base font-bold text-navy-950 transition-colors hover:bg-gold-500"
      >
        Book Now
      </a>
    </div>
  </section>
</BaseLayout>
