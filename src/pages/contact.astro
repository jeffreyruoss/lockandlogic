---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout title="Contact Us" description="Get in touch with Lock & Logic. Questions about our escape rooms, bookings, or events? We're here to help.">
  <PageHero title="Contact Us" subtitle="Have a question? We'd love to hear from you." />

  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2">
        <!-- Contact Form -->
        <div>
          <h2 class="mb-6 font-heading text-2xl font-bold text-steel-100">Send Us a Message</h2>
          <ContactForm />
        </div>

        <!-- Contact Info Cards -->
        <div class="space-y-6">
          <div class="rounded-xl border border-navy-700/50 bg-navy-900 p-6">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-gold-400/10">
              <svg class="h-5 w-5 text-gold-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
            </div>
            <h3 class="mb-1 font-heading text-lg font-bold text-steel-100">Address</h3>
            <p class="text-sm text-steel-400">Pottstown, PA</p>
            <p class="text-xs text-steel-400">Full address coming soon</p>
          </div>

          <div class="rounded-xl border border-navy-700/50 bg-navy-900 p-6">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-gold-400/10">
              <svg class="h-5 w-5 text-gold-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
              </svg>
            </div>
            <h3 class="mb-1 font-heading text-lg font-bold text-steel-100">Phone</h3>
            <a href="tel:+10000000000" class="text-sm text-steel-400 transition-colors hover:text-gold-300">(000) 000-0000</a>
          </div>

          <div class="rounded-xl border border-navy-700/50 bg-navy-900 p-6">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-gold-400/10">
              <svg class="h-5 w-5 text-gold-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
            </div>
            <h3 class="mb-1 font-heading text-lg font-bold text-steel-100">Email</h3>
            <a href="mailto:info@lockandlogic.com" class="text-sm text-steel-400 transition-colors hover:text-gold-300">info@lockandlogic.com</a>
          </div>

          <div class="rounded-xl border border-navy-700/50 bg-navy-900 p-6">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-gold-400/10">
              <svg class="h-5 w-5 text-gold-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>
            <h3 class="mb-1 font-heading text-lg font-bold text-steel-100">Hours</h3>
            <div class="text-sm text-steel-400">
              <p>Mon–Thu: 4:00 PM – 10:00 PM</p>
              <p>Fri: 2:00 PM – 11:00 PM</p>
              <p>Sat: 10:00 AM – 11:00 PM</p>
              <p>Sun: 10:00 AM – 8:00 PM</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="border-t border-navy-700/50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="overflow-hidden rounded-xl border border-navy-700/50">
        <div class="flex h-80 items-center justify-center bg-navy-900">
          <div class="text-center">
            <svg class="mx-auto mb-3 h-10 w-10 text-steel-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z" />
            </svg>
            <p class="text-sm text-steel-400">Google Maps embed will appear here</p>
            <p class="text-xs text-steel-400">Pottstown, PA</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
