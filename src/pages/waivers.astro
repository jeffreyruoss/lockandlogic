---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { baseUrl } from '../utils/url';
---

<BaseLayout title="Digital Waiver" description="Complete your digital waiver before your escape room visit at Lock & Logic.">
  <PageHero title="Digital Waiver" subtitle="Complete your waiver before you arrive to speed up check-in." />

  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <div class="overflow-hidden rounded-xl border border-navy-700/50 bg-navy-900">
          <div class="flex min-h-[400px] flex-col items-center justify-center px-6 py-16 text-center">
            <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-full border border-gold-400/20 bg-gold-400/5">
              <svg class="h-8 w-8 text-gold-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
              </svg>
            </div>
            <p class="mb-2 font-heading text-lg font-bold text-steel-100">Digital Waiver Coming Soon</p>
            <p class="mb-6 text-sm text-steel-400">
              We're setting up our digital waiver system. In the meantime, waivers will be available on-site when you arrive.
            </p>
            <a
              href={baseUrl('/contact')}
              class="inline-flex items-center gap-2 rounded-lg bg-gold-400 px-6 py-3 font-heading text-sm font-bold text-navy-950 transition hover:bg-gold-300"
            >
              Contact Us
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Info Note -->
      <div class="mt-12 mx-auto max-w-2xl">
        <div class="rounded-xl border border-navy-700/50 bg-navy-900 p-6">
          <h2 class="mb-4 font-heading text-xl font-bold text-steel-100">Important Information</h2>
          <ul class="space-y-3 text-sm text-steel-400">
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-gold-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
              </svg>
              <span><strong class="text-steel-100">All participants</strong> must complete a waiver before playing, including returning visitors.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-gold-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
              </svg>
              <span><strong class="text-steel-100">Minors (under 18)</strong> must have their waiver signed by a parent or legal guardian.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-gold-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
              </svg>
              <span>Signed waivers are <strong class="text-steel-100">valid for 12 months</strong> from the date of signing.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
