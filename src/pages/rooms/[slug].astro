---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RoomCard from '../../components/RoomCard.astro';
import { rooms } from '../../data/rooms';
import type { Room } from '../../data/rooms';

export function getStaticPaths() {
  return rooms.map((room) => ({
    params: { slug: room.slug },
    props: { room },
  }));
}

interface Props {
  room: Room;
}

const { room } = Astro.props;
const otherRooms = rooms.filter((r) => r.slug !== room.slug);

const difficultyColors: Record<string, string> = {
  Beginner: 'bg-teal-400/20 text-teal-400',
  Intermediate: 'bg-gold-400/20 text-gold-400',
  Advanced: 'bg-red-500/20 text-red-400',
};

const stats = [
  { label: 'Players', value: room.players, icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128H9m6 0a5.972 5.972 0 0 0-.786-3.07M9 19.128v-.003c0-1.113.285-2.16.786-3.07m0 0a5.972 5.972 0 0 1 6.428 0M9.786 16.058A5.967 5.967 0 0 1 12 15c1.05 0 2.034.27 2.893.739M12 12a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />' },
  { label: 'Duration', value: room.duration, icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />' },
  { label: 'Price', value: room.price, icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />' },
];
---

<BaseLayout title={room.name} description={room.fullDescription.slice(0, 160)}>
  <!-- Room Hero -->
  <section class="relative overflow-hidden py-20 sm:py-28">
    <div
      class={`absolute inset-0 bg-gradient-to-br ${room.gradientFrom} ${room.gradientTo}`}
      aria-hidden="true"
    ></div>
    <div class="absolute inset-0 bg-navy-950/70" aria-hidden="true"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-gold-400/20 to-transparent" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <span class={`inline-block rounded-full px-4 py-1.5 text-xs font-bold ${difficultyColors[room.difficulty]} mb-4`}>
        {room.difficulty}
      </span>
      <h1 class="text-gold-gradient font-heading text-4xl font-bold sm:text-5xl lg:text-6xl">{room.name}</h1>
      <p class="mt-4 text-lg text-steel-200">{room.tagline}</p>
    </div>
  </section>

  <!-- Room Details -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <!-- Main content (3 cols) -->
        <div class="lg:col-span-3">
          <h2 class="mb-6 font-heading text-2xl font-bold text-steel-100">About This Room</h2>
          <p class="mb-8 leading-relaxed text-steel-200">{room.fullDescription}</p>

          <h3 class="mb-4 font-heading text-xl font-bold text-steel-100">Room Highlights</h3>
          <ul class="mb-8 space-y-3">
            {room.highlights.map((highlight) => (
              <li class="flex items-start gap-3 text-steel-200">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-teal-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                {highlight}
              </li>
            ))}
          </ul>

          <!-- Stat cards -->
          <div class="grid gap-4 sm:grid-cols-3">
            {stats.map((stat) => (
              <div class="rounded-xl border border-navy-700/50 bg-navy-900 p-4 text-center">
                <svg class="mx-auto mb-2 h-6 w-6 text-gold-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" set:html={stat.icon} />
                <p class="text-xs text-steel-400">{stat.label}</p>
                <p class="font-heading text-lg font-bold text-steel-100">{stat.value}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Sidebar (2 cols) -->
        <div class="lg:col-span-2">
          <!-- Photo placeholders -->
          <div class="mb-6 grid grid-cols-2 gap-3">
            <div class={`col-span-2 h-48 rounded-xl bg-gradient-to-br ${room.gradientFrom} ${room.gradientTo} opacity-60`}></div>
            <div class={`h-32 rounded-xl bg-gradient-to-br ${room.gradientFrom} ${room.gradientTo} opacity-40`}></div>
            <div class={`h-32 rounded-xl bg-gradient-to-br ${room.gradientFrom} ${room.gradientTo} opacity-40`}></div>
          </div>

          <!-- Sticky booking CTA -->
          <div class="rounded-xl border border-gold-400/20 bg-navy-900 p-6 lg:sticky lg:top-24">
            <h3 class="mb-2 font-heading text-xl font-bold text-steel-100">Ready to Play?</h3>
            <p class="mb-1 text-sm text-steel-400">{room.price} &middot; {room.duration} &middot; {room.players}</p>
            <p class="mb-6 text-sm text-steel-400">{room.difficulty} difficulty</p>
            <a
              href={`/book?room=${room.slug}`}
              class="block rounded-lg bg-gold-400 px-6 py-3 text-center text-sm font-bold text-navy-950 transition-colors hover:bg-gold-500"
            >
              Book This Room
            </a>
            <a
              href="/gift-cards"
              class="mt-3 block text-center text-sm text-gold-400 transition-colors hover:text-gold-300"
            >
              Or give as a gift card
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Other Rooms -->
  <section class="border-t border-navy-700/50 bg-navy-900 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center font-heading text-2xl font-bold text-steel-100">Explore Our Other Rooms</h2>
      <div class="grid gap-6 md:grid-cols-2">
        {otherRooms.map((r) => (
          <RoomCard
            name={r.name}
            description={r.description}
            difficulty={r.difficulty}
            players={r.players}
            duration={r.duration}
            price={r.price}
            slug={r.slug}
            gradientFrom={r.gradientFrom}
            gradientTo={r.gradientTo}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
